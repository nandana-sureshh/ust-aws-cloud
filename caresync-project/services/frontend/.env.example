# CareSync Frontend — Environment Variables
# The frontend no longer uses build-time REACT_APP_* variables.
# API calls use relative paths (/api/*) proxied by nginx to the Internal ALB.
#
# The only runtime variable needed is INTERNAL_ALB_DNS.
# Set this in docker-compose environment: or EC2 User Data before running:
#   docker compose up -d frontend
#
# For production: set to your Internal ALB DNS hostname (without http://)
# Example: internal-caresync-alb-123456789.us-east-1.elb.amazonaws.com
INTERNAL_ALB_DNS=localhost
