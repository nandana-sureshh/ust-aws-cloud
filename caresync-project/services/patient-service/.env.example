# CareSync Patient Service — Environment Variables
# Copy to .env for local development outside Docker.
# For production (EC2/ASG): inject these via EC2 User Data, AWS SSM, or Secrets Manager.

PORT=4002
NODE_ENV=production

MONGO_URI=mongodb://localhost:27017/patientdb

# Generate with: openssl rand -base64 32
JWT_SECRET=change_this_to_a_strong_random_secret
AUTH_SERVICE_URL=http://localhost:4001

# Comma-separated list of allowed browser origins (External ALB DNS on production).
ALLOWED_ORIGINS=http://localhost:8080
