# CareSync Auth Service — Environment Variables
# Copy to .env for local development outside Docker.
# For production (EC2/ASG): inject these via EC2 User Data, AWS SSM, or Secrets Manager.

PORT=4001
NODE_ENV=production

MONGO_URI=mongodb://localhost:27017/authdb

# Generate with: openssl rand -base64 32
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed browser origins (External ALB DNS on production).
# Example (production): ALLOWED_ORIGINS=http://external-caresync-alb-xyz.us-east-1.elb.amazonaws.com
ALLOWED_ORIGINS=http://localhost:8080
